// middleware.ts – FolioFrame SaaS Live – July 2026
// Restores Clerk protection – removed in b69ec3f – re-enabled with billing awareness
import { clerkMiddleware } from "@clerk/nextjs/server";
import { NextResponse, type NextRequest, type NextFetchEvent } from "next/server";
import { isClerkConfigured } from "@/lib/auth/config";

const protectInternalAppRoutes = isClerkConfigured()
  ? clerkMiddleware(async (auth) => {
      await auth.protect();
    })
  : null;

export default function middleware(request: NextRequest, event: NextFetchEvent) {
  // Allow public marketing + pricing + Stripe webhooks
  const publicPaths = [
    "/",
    "/pricing",
    "/pricing/live",
    "/foliofix",
    "/signature-launch",
    "/modules",
    "/faq",
    "/sign-in",
    "/sign-up",
    "/api/webhooks/stripe",
    "/api/billing",
  ];

  if (publicPaths.some((p) => request.nextUrl.pathname === p || request.nextUrl.pathname.startsWith(p + "/"))) {
    // still run Clerk to populate session, but don't protect
    if (request.nextUrl.pathname.startsWith("/api/webhooks")) {
      return NextResponse.next();
    }
  }

  // workspace setup remains open for onboarding funnel
  if (request.nextUrl.pathname.startsWith("/app/workspace-setup")) {
    return NextResponse.next();
  }

  if (!protectInternalAppRoutes) {
    return NextResponse.next();
  }

  // Protect /app/*
  if (request.nextUrl.pathname.startsWith("/app")) {
    return protectInternalAppRoutes(request, event);
  }

  return NextResponse.next();
}

export const config = {
  matcher: [
    // Skip Next.js internals and static files
    "/((?!_next|[^?]*\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)",
    "/(api|trpc)(.*)",
  ],
};
